# Copy to .env (or export these) before running the marketplace server.

# Postgres connection string.
DATABASE_URL=postgres://artex:artex@localhost:5432/artex_marketplace

# Address the server binds to.
BIND_ADDR=0.0.0.0:8787

# Public base URL the registry advertises in manifestUrl fields. Must be how
# the Artex app reaches this server (e.g. https://market.example.com).
PUBLIC_BASE_URL=http://localhost:8787

# Log filter (tracing-subscriber EnvFilter syntax).
RUST_LOG=info,artex_marketplace=debug
